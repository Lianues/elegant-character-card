{
  "name": "elegant-character-card",
  "version": "0.1.2",
  "description": "Elegant Character Card CLI-only toolkit (SillyTavern compatible)",
  "license": "GPL-3.0-only",
  "author": "Lianues",
  "type": "module",
  "bin": {
    "elegant-character-card": "dist/cli/index.js",
    "ecc": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "sillytavern",
    "character-card",
    "tavern",
    "cli",
    "png",
    "yaml",
    "ecc"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Lianues/elegant-character-card.git"
  },
  "homepage": "https://github.com/Lianues/elegant-character-card#readme",
  "bugs": {
    "url": "https://github.com/Lianues/elegant-character-card/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-assets.cjs",
    "dev": "tsx src/cli/index.ts",
    "start": "node dist/cli/index.js",
    "test": "vitest run",
    "prepublishOnly": "npm run build",
    "link": "npm run build && npm link",
    "unlink": "npm unlink -g elegant-character-card"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "png-chunk-text": "^1.0.0",
    "png-chunks-encode": "^1.0.0",
    "png-chunks-extract": "^1.0.0",
    "yaml": "^2.6.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
